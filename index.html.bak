<script>
/* ------------------------------------------------------------
   In-page anchor scroll (footer + header Program, etc.)
   Ensures clicking always smooth-scrolls even when the URL
   hash is already set to that target.
------------------------------------------------------------ */
(function () {
  /* Match both anchor links with hash hrefs AND buttons with data-scroll-target.
     Buttons have no href so they can never navigate even if JS fails. */
  const triggers = document.querySelectorAll('a[href^="#"], [data-scroll-target]');
  if (!triggers.length) return;

  function getTargetId(el) {
    const dataTarget = el.getAttribute('data-scroll-target');
    if (dataTarget) return dataTarget;
    const href = el.getAttribute('href');
    if (href && href !== '#' && href.length > 1) return href.slice(1);
    return null;
  }

  triggers.forEach(trigger => {
    const targetId = getTargetId(trigger);
    if (!targetId) return;

    trigger.addEventListener('click', (e) => {
      /* Always preventDefault FIRST so the browser can never navigate */
      e.preventDefault();

      const target = document.getElementById(targetId);
      if (!target) return;

      /* Close mobile menu first, then scroll after brief settle */
      const wasMenuOpen = document.body.classList.contains('menu-open');
      if (wasMenuOpen) {
        document.body.classList.remove('menu-open');
        const navToggle = document.getElementById('navToggle');
        if (navToggle) navToggle.setAttribute('aria-expanded', 'false');
      }

      const doScroll = () => {
        try {
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        } catch (err) {
          target.scrollIntoView();
        }
        try {
          if (history.pushState) history.pushState(null, '', '#' + targetId);
        } catch (err) { /* iframe sandboxes may block pushState */ }
      };

      if (wasMenuOpen) setTimeout(doScroll, 320);
      else doScroll();
    });
  });
})();

/* ------------------------------------------------------------
   Copy to clipboard (footer phone / email) — silent
------------------------------------------------------------ */
(function () {
  const triggers = document.querySelectorAll('[data-copy]');
  if (!triggers.length) return;

  function fallbackCopy(text) {
    const ta = document.createElement('textarea');
    ta.value = text;
    ta.style.position = 'fixed';
    ta.style.opacity = '0';
    ta.style.left = '-9999px';
    document.body.appendChild(ta);
    ta.select();
    try { document.execCommand('copy'); } catch (e) {}
    document.body.removeChild(ta);
  }

  triggers.forEach(el => {
    el.addEventListener('click', (e) => {
      e.preventDefault();
      const text = el.getAttribute('data-copy');
      if (!text) return;
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(text).catch(() => fallbackCopy(text));
      } else {
        fallbackCopy(text);
      }
    });
  });
})();

/* ------------------------------------------------------------
   Modal — open/close + focus management
------------------------------------------------------------ */
(function () {
  const modals = document.querySelectorAll('.modal-overlay');
  if (!modals.length) return;

  let triggerEl = null;

  function openModal(modal) {
    /* Close mobile menu if it's open */
    document.body.classList.remove('menu-open');
    const navToggle = document.getElementById('navToggle');
    if (navToggle) navToggle.setAttribute('aria-expanded', 'false');

    modal.classList.add('is-open');
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';

    /* Focus the close button after the panel slides in */
    const closeBtn = modal.querySelector('[data-modal-close]');
    if (closeBtn) setTimeout(() => closeBtn.focus(), 120);
  }

  function closeModal(modal) {
    modal.classList.remove('is-open');
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    if (triggerEl) {
      try { triggerEl.focus(); } catch (e) {}
      triggerEl = null;
    }
  }

  /* Open triggers */
  document.querySelectorAll('[data-modal-open]').forEach(el => {
    el.addEventListener('click', (e) => {
      e.preventDefault();
      const id = el.getAttribute('data-modal-open');
      const modal = document.getElementById(id);
      if (!modal) return;
      triggerEl = el;
      openModal(modal);
    });
  });

  /* Close triggers within each modal */
  modals.forEach(modal => {
    modal.querySelectorAll('[data-modal-close]').forEach(el => {
      el.addEventListener('click', () => closeModal(modal));
    });

    /* Click on overlay (outside the panel) closes */
    modal.addEventListener('click', (e) => {
      if (e.target === modal) closeModal(modal);
    });
  });

  /* Escape closes any open modal */
  document.addEventListener('keydown', (e) => {
    if (e.key !== 'Escape') return;
    modals.forEach(modal => {
      if (modal.classList.contains('is-open')) closeModal(modal);
    });
  });

  /* Sponsor form fake-submit (replace with real endpoint when ready) */
  const sponsorForm = document.getElementById('sponsorForm');
  const sponsorApply = document.getElementById('sponsorApply');
  if (sponsorForm && sponsorApply) {
    sponsorForm.addEventListener('submit', (e) => {
      e.preventDefault();
      sponsorApply.classList.add('submitted');
    });
  }
})();

/* ------------------------------------------------------------
   Scroll to top (masthead mark)
------------------------------------------------------------ */
(function () {
  const triggers = document.querySelectorAll('[data-scroll-top]');
  if (!triggers.length) return;

  triggers.forEach(el => {
    el.addEventListener('click', (e) => {
      e.preventDefault();
      try {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      } catch (err) {
        window.scrollTo(0, 0);
      }
      try {
        if (history.pushState) history.pushState(null, '', window.location.pathname);
      } catch (err) { /* iframe sandboxes may block pushState */ }
    });
  });
})();

/* ------------------------------------------------------------
   Mobile sticky CTA — hide near top, show after scroll past hero
------------------------------------------------------------ */
(function () {
  const cta = document.querySelector('.mobile-sticky-cta');
  if (!cta) return;
  const hero = document.querySelector('.hero');
  if (!hero) return;

  let ticking = false;
  function update() {
    const heroBottom = hero.getBoundingClientRect().bottom;
    if (heroBottom > 80) cta.classList.add('is-hidden');
    else cta.classList.remove('is-hidden');
    ticking = false;
  }

  window.addEventListener('scroll', () => {
    if (!ticking) {
      requestAnimationFrame(update);
      ticking = true;
    }
  }, { passive: true });

  update();
})();

/* ------------------------------------------------------------
   Mobile nav toggle
------------------------------------------------------------ */
(function () {
  const toggle = document.getElementById('navToggle');
  const menu = document.getElementById('mobileMenu');
  if (!toggle || !menu) return;

  function open() {
    document.body.classList.add('menu-open');
    toggle.setAttribute('aria-expanded', 'true');
    menu.setAttribute('aria-hidden', 'false');
    toggle.setAttribute('aria-label', 'Close menu');
  }
  function close() {
    document.body.classList.remove('menu-open');
    toggle.setAttribute('aria-expanded', 'false');
    menu.setAttribute('aria-hidden', 'true');
    toggle.setAttribute('aria-label', 'Open menu');
  }
  function toggleMenu() {
    if (document.body.classList.contains('menu-open')) close();
    else open();
  }

  toggle.addEventListener('click', toggleMenu);

  /* Close on link click */
  menu.querySelectorAll('a, button').forEach(el => {
    el.addEventListener('click', close);
  });

  /* Close on Escape */
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && document.body.classList.contains('menu-open')) close();
  });

  /* Close if window resized above mobile breakpoint */
  let resizeTimer;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => {
      if (window.innerWidth > 880 && document.body.classList.contains('menu-open')) close();
    }, 150);
  });
})();

/* ------------------------------------------------------------
   Reveal on scroll
------------------------------------------------------------ */
(function () {
  const els = document.querySelectorAll('.reveal');
  if (!('IntersectionObserver' in window)) {
    els.forEach(el => el.classList.add('in'));
    return;
  }
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('in');
        io.unobserve(e.target);
      }
    });
  }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
  els.forEach(el => io.observe(el));
})();

/* ------------------------------------------------------------
   Countdown to June 5, 2026 (festival opens)
------------------------------------------------------------ */
(function () {
  const target = new Date('2026-06-05T17:00:00-06:00').getTime();
  const d = document.getElementById('cd-d');
  const h = document.getElementById('cd-h');
  const m = document.getElementById('cd-m');
  const s = document.getElementById('cd-s');
  if (!d) return;

  function pad(n) { return String(n).padStart(2, '0'); }

  function tick() {
    const now = Date.now();
    let diff = Math.max(0, target - now);
    const days = Math.floor(diff / 86400000); diff -= days * 86400000;
    const hours = Math.floor(diff / 3600000); diff -= hours * 3600000;
    const mins = Math.floor(diff / 60000); diff -= mins * 60000;
    const secs = Math.floor(diff / 1000);
    d.textContent = days;
    h.textContent = pad(hours);
    m.textContent = pad(mins);
    s.textContent = pad(secs);
  }
  tick();
  setInterval(tick, 1000);
})();
</script>




