        <div>
          <div class="day-no">Day 01</div>
          <div class="day-day">Friday — June 5</div>
          <h3 class="day-name">VIP <em>Dinner</em></h3>
        </div>
        <svg class="day-icon" viewBox="0 0 76 76" aria-hidden="true">
          <path d="M20 14 L56 14 C 56 30, 48 42, 38 42 C 28 42, 20 30, 20 14"/>
