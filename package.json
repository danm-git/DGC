{
  "name": "dgc",
  "version": "0.0.0",
  "private": true,
  "description": "DGC Growers' Festival 2026 — static site",
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:html": "htmlhint \"**/*.html\"",
